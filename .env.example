# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- Database ---
# Local Docker Compose stack (see README):
#   MONGODB_URI=mongodb://localhost:27017
# Atlas / cloud dev:
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=what_the_rep

# --- Anthropic Claude API ---
# UNUSED until Phase 4 (the ask_agent agentic layer — see MASTER_PLAN §8).
# Kept server-side only; never sent to the browser.
ANTHROPIC_API_KEY=

# --- Rate limiting / abuse prevention (MASTER_PLAN §9) ---
# Read-only / DB-only tier (generous).
RATE_LIMIT_READ_PER_MIN=60
RATE_LIMIT_READ_PER_DAY=1000
# HTTP hygiene (body size, concurrency, timeout).
MCP_MAX_REQUEST_BODY_BYTES=1048576
MCP_MAX_CONCURRENT_REQUESTS_PER_IP=10
MCP_REQUEST_TIMEOUT_SECONDS=30
# MCP server bind (Streamable HTTP).
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Browser origins allowed to call the MCP HTTP transport (comma-separated).
# Required when the frontend runs on a different port than the backend (e.g. Docker Compose).
MCP_CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Semantic search tier (moderate).
RATE_LIMIT_SEMANTIC_PER_MIN=20
# Agentic (paid LLM) tier — strict per-IP + a global daily budget cap.
RATE_LIMIT_AGENT_PER_HOUR=5
AGENT_DAILY_BUDGET_CALLS=200

# --- Frontend (Vite build-time; see frontend/.env or docker-compose build args) ---
# Must be reachable from the host browser — not a Docker Compose internal hostname.
VITE_MCP_URL=http://localhost:8000/mcp/
